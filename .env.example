# Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=[123456789]

# Database
DB_PATH=storage/bot.db

# AI & RAG Configuration (NEW)
GEMINI_API_KEY=your_gemini_api_key_here
ENABLE_RAG=true
CHROMA_DB_PATH=storage/chroma_db
RAG_TOP_K=3
LLM_MODEL=gemini-1.5-flash
LLM_RATE_LIMIT_PER_MIN=15

# Feature Flags
ENABLE_EXPENSE_TRACKING=true
ENABLE_VOICE_NOTES=false

# Existing Settings
LOG_LEVEL=INFO
DEFAULT_LANG=en
ENABLE_SEMANTIC_SEARCH=false
ENABLE_WHATSAPP_IMPORT=true
MAX_MEMORY_PERCENT=85
RATE_LIMIT_MSGS=10
RATE_LIMIT_WINDOW=60

# AWS (Optional)
AWS_REGION=us-east-1
EC2_INSTANCE_ID=
DEPLOY_WEBHOOK_URL=
HEALTH_CHECK_URL=
